# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-access-token

# Together AI (for Llama 3.3 70B)
TOGETHER_AI_API_KEY=your-together-ai-api-key

# Foursquare Places API (for dev seeder - optional)
# Get your API key at https://foursquare.com/developers/apps
FOURSQUARE_API_KEY=your-foursquare-api-key

# Email (Resend or Postmark)
RESEND_API_KEY=your-resend-api-key
# or
POSTMARK_API_KEY=your-postmark-api-key

# Eventbrite API (for event ingestion)
# Get your API key at https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=your-eventbrite-api-key

# Cron Secret (for protecting cron endpoints)
CRON_SECRET=your-random-secret-string

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000